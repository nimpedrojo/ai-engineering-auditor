#!/usr/bin/env bash

###############################################################################
#
# AI Engineering Auditor
#
# Command:
#   aiea-status
#
# Description:
#   Displays the current status of the AI Engineering Auditor project.
#
###############################################################################

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

VERSION="$(<"$ROOT_DIR/VERSION")"

###############################################################################
# Directories
###############################################################################

PROJECT_ROOT=""
AUDITOR_DIR=""

PROJECT_FILE=""
STATE_FILE=""
EVENTS_FILE=""
METRICS_FILE=""
REPORT_FILE=""
DECISIONS_FILE=""

###############################################################################
# Console
###############################################################################

print_header() {

    echo
    echo "============================================================"
    echo " AI Engineering Auditor v${VERSION}"
    echo "============================================================"
    echo

}

error() {

    echo
    echo "ERROR: $1"
    echo
    exit 1

}

###############################################################################
# Project detection
###############################################################################

find_project_root() {

    if git rev-parse --show-toplevel >/dev/null 2>&1
    then
        git rev-parse --show-toplevel
        return
    fi

    pwd

}

prepare_paths() {

    PROJECT_ROOT="$(find_project_root)"

    AUDITOR_DIR="$PROJECT_ROOT/docs/ai-auditor"

    PROJECT_FILE="$AUDITOR_DIR/project.json"
    STATE_FILE="$AUDITOR_DIR/state.json"
    EVENTS_FILE="$AUDITOR_DIR/events.jsonl"
    METRICS_FILE="$AUDITOR_DIR/metrics.json"
    REPORT_FILE="$AUDITOR_DIR/report.md"
    DECISIONS_FILE="$AUDITOR_DIR/decisions.md"

}

###############################################################################
# Validation
###############################################################################

validate() {

    [[ -d "$AUDITOR_DIR" ]] \
        || error "AI Engineering Auditor has not been initialized."

    [[ -f "$PROJECT_FILE" ]] \
        || error "project.json not found."

    [[ -f "$STATE_FILE" ]] \
        || error "state.json not found."

}

###############################################################################
# JSON helper
###############################################################################

json_value() {

    local file="$1"
    local field="$2"

    python3 <<EOF
import json

with open(r"$file","r",encoding="utf-8") as f:
    data=json.load(f)

value=data.get("$field")

if value is None:
    print("")
else:
    print(value)
EOF

}

###############################################################################
# Counters
###############################################################################

count_events() {

    if [[ ! -f "$EVENTS_FILE" ]]
    then
        echo 0
        return
    fi

    wc -l < "$EVENTS_FILE" | tr -d ' '

}

count_decisions() {

    if [[ ! -f "$DECISIONS_FILE" ]]
    then
        echo 0
        return
    fi

    python3 <<EOF
from pathlib import Path

path = Path(r"$DECISIONS_FILE")

if not path.exists():
    print(0)
    raise SystemExit

lines = path.read_text(encoding="utf-8").splitlines()

count = 0

for line in lines:

    line = line.strip()

    if not line.startswith("|"):
        continue

    if line.startswith("| Date "):
        continue

    if set(line.replace("|", "").replace("-", "").replace(" ", "")) == set():
        continue

    count += 1

print(count)
EOF

}

###############################################################################
# Status
###############################################################################

print_status() {

    local project
    local status
    local phase

    project="$(json_value "$PROJECT_FILE" "name")"
    status="$(json_value "$STATE_FILE" "status")"
    phase="$(json_value "$STATE_FILE" "currentPhase")"

    echo "Project"
    echo "-------"
    printf "%-18s %s\n" "Name" "$project"
    printf "%-18s %s\n" "Status" "$status"
    printf "%-18s %s\n" "Phase" "$phase"

    echo
    echo "Current Task"
    echo "------------"
    printf "%-18s %s\n" "Task" "None"

    echo
    echo "Project Metrics"
    echo "---------------"
    printf "%-18s %s\n" "Events" "$(count_events)"
    printf "%-18s %s\n" "Decisions" "$(count_decisions)"

    echo
    echo "Files"
    echo "-----"

    for file in \
        "$PROJECT_FILE" \
        "$STATE_FILE" \
        "$EVENTS_FILE" \
        "$METRICS_FILE" \
        "$REPORT_FILE"
    do

        if [[ -f "$file" ]]
        then
            printf "✔ %s\n" "$(basename "$file")"
        else
            printf "✘ %s\n" "$(basename "$file")"
        fi

    done

    echo
    echo "Workspace"
    echo "---------"
    echo "$PROJECT_ROOT"

    echo
    echo "============================================================"

}

###############################################################################
# Main
###############################################################################

main() {

    print_header

    prepare_paths

    validate

    print_status

}

main "$@"