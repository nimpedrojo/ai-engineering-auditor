#!/usr/bin/env bash

###############################################################################
#
# AI Engineering Auditor
#
# Command:
#   aiea-task
#
# Description:
#   Manages the current task state for AI Engineering Auditor.
#
###############################################################################

set -euo pipefail

###############################################################################
# Bootstrap
###############################################################################

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

VERSION="$(<"$ROOT_DIR/VERSION")"

PROJECT_ROOT=""
AUDITOR_DIR=""
STATE_FILE=""

COMMAND="${1:-}"

###############################################################################
# Console
###############################################################################

print_header() {
    echo
    echo "============================================================"
    echo " AI Engineering Auditor v${VERSION}"
    echo "============================================================"
    echo
}

error() {
    echo
    printf "ERROR: %s\n" "$1"
    echo
    exit 1
}

success() {
    printf "✔ %s\n" "$1"
}

info() {
    printf "• %s\n" "$1"
}

###############################################################################
# Help
###############################################################################

print_help() {
    cat <<EOF

Usage:
  aiea-task start "Task title"
  aiea-task close
  aiea-task status

Commands:
  start     Starts a new active task.
  close     Closes the current active task.
  status    Shows the current active task.

Examples:
  aiea-task start "Analyze Realm persistence"
  aiea-task close
  aiea-task status

EOF
}

###############################################################################
# Project detection
###############################################################################

find_project_root() {
    if git rev-parse --show-toplevel >/dev/null 2>&1
    then
        git rev-parse --show-toplevel
        return
    fi

    pwd
}

prepare_paths() {
    PROJECT_ROOT="$(find_project_root)"
    AUDITOR_DIR="$PROJECT_ROOT/docs/ai-auditor"
    STATE_FILE="$AUDITOR_DIR/state.json"
}

validate_auditor() {
    [[ -d "$AUDITOR_DIR" ]] \
        || error "AI Engineering Auditor has not been initialized."

    [[ -f "$STATE_FILE" ]] \
        || error "state.json not found."
}

validate_python() {
    if command -v python3 >/dev/null 2>&1
    then
        PYTHON_CMD="python3"
        return
    fi

    if command -v python >/dev/null 2>&1
    then
        PYTHON_CMD="python"
        return
    fi

    error "Python not found."
}

###############################################################################
# State operations
###############################################################################

task_status() {
    "$PYTHON_CMD" <<EOF
import json
from pathlib import Path

state_file = Path(r"$STATE_FILE")

data = json.loads(state_file.read_text(encoding="utf-8"))

task = data.get("currentTask")

print()
print("Current Task")
print("------------")

if task is None:
    print("None")
else:
    print(task)

print()
EOF
}

task_start() {
    local title="${2:-}"

    [[ -n "$title" ]] \
        || error "Task title is required. Example: aiea-task start \"Analyze Realm persistence\""

    "$PYTHON_CMD" <<EOF
import json
from pathlib import Path
from datetime import datetime, timezone

state_file = Path(r"$STATE_FILE")

data = json.loads(state_file.read_text(encoding="utf-8"))

if data.get("currentTask") is not None:
    raise SystemExit("ERROR: There is already an active task. Close it before starting a new one.")

now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

data["currentTask"] = """$title"""
data["currentAIInteraction"] = None
data["status"] = "TaskActive"
data["updatedAt"] = now

state_file.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
EOF

    echo
    success "Task started"
    echo
    printf "%-18s %s\n" "Task" "$title"
    echo
}

task_close() {
    "$PYTHON_CMD" <<EOF
import json
from pathlib import Path
from datetime import datetime, timezone

state_file = Path(r"$STATE_FILE")

data = json.loads(state_file.read_text(encoding="utf-8"))

if data.get("currentTask") is None:
    raise SystemExit("ERROR: There is no active task to close.")

closed_task = data.get("currentTask")

now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

data["currentTask"] = None
data["currentAIInteraction"] = None
data["status"] = "Ready"
data["updatedAt"] = now

state_file.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")

print(closed_task)
EOF
}

run_close() {
    local closed_task

    closed_task="$(task_close)"

    echo
    success "Task closed"
    echo
    printf "%-18s %s\n" "Task" "$closed_task"
    echo
}

###############################################################################
# Main
###############################################################################

main() {
    case "$COMMAND" in
        ""|"-h"|"--help")
            print_help
            exit 0
            ;;
        "--version")
            echo "$VERSION"
            exit 0
            ;;
    esac

    prepare_paths
    validate_auditor
    validate_python

    case "$COMMAND" in
        "start")
            task_start "$@"
            ;;
        "close")
            run_close
            ;;
        "status")
            task_status
            ;;
        *)
            error "Unknown command: $COMMAND"
            ;;
    esac
}

main "$@"