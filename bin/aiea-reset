#!/usr/bin/env bash

###############################################################################
#
# AI Engineering Auditor
#
# Command:
#   aiea-reset
#
# Description:
#   Removes AI Engineering Auditor files from the current project.
#   Intended for development and testing.
#
###############################################################################

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

VERSION="$(<"$ROOT_DIR/VERSION")"

PROJECT_ROOT=""
AUDITOR_DIR=""

print_header() {
    echo
    echo "============================================================"
    echo " AI Engineering Auditor v${VERSION}"
    echo "============================================================"
    echo
}

error() {
    echo
    printf "ERROR: %s\n" "$1"
    echo
    exit 1
}

success() {
    printf "✔ %s\n" "$1"
}

find_project_root() {
    if git rev-parse --show-toplevel >/dev/null 2>&1
    then
        git rev-parse --show-toplevel
        return
    fi

    pwd
}

prepare_paths() {
    PROJECT_ROOT="$(find_project_root)"
    AUDITOR_DIR="$PROJECT_ROOT/docs/ai-auditor"
}

confirm_reset() {
    echo "This will remove:"
    echo
    echo "$AUDITOR_DIR"
    echo
    printf "Continue? Type YES: "
    read -r answer

    if [[ "$answer" != "YES" ]]
    then
        error "Reset cancelled."
    fi
}

reset_auditor() {
    if [[ ! -d "$AUDITOR_DIR" ]]
    then
        error "AI Engineering Auditor is not initialized in this project."
    fi

    rm -rf "$AUDITOR_DIR"
}

main() {
    print_header
    prepare_paths
    confirm_reset
    reset_auditor

    success "AI Engineering Auditor reset completed."
    echo
}

main "$@"