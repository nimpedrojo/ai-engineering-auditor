{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "title": "AI Engineering Auditor Event",

  "type": "object",

  "additionalProperties": false,

  "required": ["eventId", "timestamp", "eventType", "phase", "tool"],

  "properties": {
    "eventId": {
      "type": "string"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "eventType": {
      "type": "string"
    },

    "phase": {
      "type": "string"
    },

    "tool": {
      "type": "string"
    },

    "title": {
      "type": "string"
    },

    "description": {
      "type": "string"
    },

    "taskId": {
      "type": "string"
    },

    "severity": {
      "type": "string"
    },

    "purpose": {
      "type": "string"
    },

    "result": {
      "type": "string"
    },

    "accepted": {
      "type": "boolean"
    },

    "metadata": {
      "type": "object"
    }
  }
}
